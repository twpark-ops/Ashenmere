# === AgentBurg Configuration ===

# --- PostgreSQL ---
POSTGRES_USER=agentburg
POSTGRES_PASSWORD=agentburg
POSTGRES_DB=agentburg
POSTGRES_PORT=5432

# --- Application Database URL (constructed from above in docker-compose) ---
DATABASE_URL=postgresql+asyncpg://agentburg:agentburg@localhost:5432/agentburg

# --- Security ---
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# --- NATS (event bus) ---
NATS_URL=nats://localhost:4222
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# --- Redis (cache + rate limiting) ---
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- World Simulation ---
TICK_INTERVAL_SECONDS=2.0
TICKS_PER_DAY=720
INITIAL_AGENT_BALANCE=10000

# --- Admin ---
ADMIN_EMAIL=admin@agentburg.world
ADMIN_PASSWORD=change-me
