# === AgentBurg Server Configuration ===

# Database
DATABASE_URL=postgresql+asyncpg://agentburg:agentburg@localhost:5432/agentburg

# Security
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# NATS (event bus)
NATS_URL=nats://localhost:4222

# Redis (cache + rate limiting)
REDIS_URL=redis://localhost:6379/0

# World simulation
TICK_INTERVAL_SECONDS=2.0
TICKS_PER_DAY=720
INITIAL_AGENT_BALANCE=10000

# Admin
ADMIN_EMAIL=admin@agentburg.world
ADMIN_PASSWORD=change-me
