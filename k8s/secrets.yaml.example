# Copy this file to secrets.yaml and replace placeholder values.
# In production, use sealed-secrets or external-secrets-operator instead.
apiVersion: v1
kind: Secret
metadata:
  name: agentburg-secrets
  namespace: agentburg
  labels:
    app.kubernetes.io/name: agentburg
type: Opaque
stringData:
  database-url: "postgresql+asyncpg://agentburg:CHANGE_ME@postgres.agentburg.svc:5432/agentburg"
  jwt-secret-key: "CHANGE_ME_TO_A_RANDOM_SECRET"
  admin-password: "CHANGE_ME_ADMIN_PASSWORD"
